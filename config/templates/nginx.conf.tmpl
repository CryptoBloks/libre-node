# Libre Node — OpenResty API Gateway Configuration
# Generated by libre-node generate-config.sh
# Template version: 3.0

worker_processes auto;
error_log /var/log/openresty/error.log warn;
pid /run/openresty.pid;

events {
    worker_connections 1024;
}

http {
    # Shared memory zones for Lua
    lua_shared_dict rate_limit 10m;
    lua_shared_dict api_keys 1m;

    # Logging
    log_format main '$remote_addr - [$time_local] key=$http_x_api_key '
                    '"$request" $status $body_bytes_sent '
                    '"$http_user_agent"';
    access_log /var/log/openresty/access.log main;

    # Timeouts
    proxy_connect_timeout 10s;
    proxy_read_timeout 30s;
    proxy_send_timeout 30s;
    keepalive_timeout 65s;
    client_max_body_size 2m;

    # --- Upstreams ---
    upstream nodeos_http {
        server 127.0.0.1:{{HTTP_PORT}};
        keepalive 32;
    }

{{SHIP_UPSTREAM}}

    # --- HTTP API server ---
    server {
        {{LISTEN_DIRECTIVE_HTTP}}
        {{TLS_DIRECTIVES}}

        # Health endpoint — no auth required
        location /health {
            access_by_lua_block { }
            proxy_pass http://nodeos_http/v1/chain/get_info;
            proxy_http_version 1.1;
            proxy_set_header Connection "";
        }

        # All API requests — auth + rate limiting
        location / {
            access_by_lua_file /etc/openresty/lua/auth.lua;

            proxy_pass http://nodeos_http;
            proxy_http_version 1.1;
            proxy_set_header Host $host;
            proxy_set_header X-Real-IP $remote_addr;
            proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
            proxy_set_header X-Forwarded-Proto $scheme;
            proxy_set_header Connection "";

            # CORS
            add_header Access-Control-Allow-Origin * always;
            add_header Access-Control-Allow-Headers * always;
            add_header Access-Control-Allow-Methods 'GET, POST, OPTIONS' always;

            if ($request_method = 'OPTIONS') {
                return 204;
            }
        }
    }

{{SHIP_SERVER_BLOCK}}
}
