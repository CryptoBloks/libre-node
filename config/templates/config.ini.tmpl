# Libre {{NETWORK}} {{NODE_ROLE}} Node Configuration
# Generated by libre-node setup wizard
# Template version: 3.0
#
# Node roles: producer, seed, light-api, full-api, full-history
# This template is processed by generate-config.sh which substitutes
# all {{PLACEHOLDER}} values based on the selected node role and network.

# ==============================================================================
# HTTP and P2P Configuration
# ==============================================================================
http-server-address = {{BIND_IP}}:{{HTTP_PORT}}
p2p-listen-endpoint = {{BIND_IP}}:{{P2P_PORT}}

# ==============================================================================
# Plugin Configuration
# ==============================================================================
# Plugins are role-dependent and injected by generate-config.sh:
#   All roles:        chain_plugin, chain_api_plugin, http_plugin, net_plugin
#   full-api:         + state_history_plugin
#   full-history:     + state_history_plugin, trace_api_plugin
#   light-api:        (base plugins only)
#   seed:             (base plugins only, no chain_api_plugin)
#   producer:         + producer_plugin, producer_api_plugin
{{PLUGINS}}

# ==============================================================================
# State History Configuration
# ==============================================================================
# Enabled for: full-api, full-history
# Disabled for: producer, seed, light-api
{{STATE_HISTORY_CONFIG}}

# ==============================================================================
# Account Queries
# ==============================================================================
# Enabled for API roles, disabled for seed/producer
enable-account-queries = true

# ==============================================================================
# Startup Behavior
# ==============================================================================
# pause-on-startup = true for producers (safety measure to prevent accidental production)
# pause-on-startup = false for all other roles
pause-on-startup = false

# ==============================================================================
# Chain Configuration
# ==============================================================================
chain-state-db-size-mb = {{CHAIN_STATE_DB_SIZE}}
wasm-runtime = eos-vm-jit

# ==============================================================================
# Logging Configuration
# ==============================================================================
contracts-console = true
verbose-http-errors = true

# ==============================================================================
# Performance Settings
# ==============================================================================
max-transaction-time = {{MAX_TRANSACTION_TIME}}
abi-serializer-max-time-ms = 12500
chain-threads = {{CHAIN_THREADS}}
http-threads = {{HTTP_THREADS}}

# ==============================================================================
# P2P Configuration
# ==============================================================================
max-clients = {{MAX_CLIENTS}}
p2p-max-nodes-per-host = 10
agent-name = "{{AGENT_NAME}}"
sync-fetch-span = 10000

# ==============================================================================
# Access Control
# ==============================================================================
# Settings vary by role:
#   API roles: open access (allow-origin = *, allow-headers = *, validate-host = false)
#   producer:  restricted to localhost
#   seed:      minimal HTTP access
{{ACCESS_CONTROL}}

# ==============================================================================
# Resource Limits
# ==============================================================================
# HTTP response time limits and in-flight byte limits
{{RESOURCE_LIMITS}}

# ==============================================================================
# Blocks Log Stride Configuration
# ==============================================================================
# Controls block log file splitting and retention
# Enabled for: full-api, full-history
# Minimal/disabled for: light-api, seed, producer
{{BLOCKS_CONFIG}}

# ==============================================================================
# P2P Peer Addresses
# ==============================================================================
# Peers are loaded from config/peers-{{NETWORK}}.conf
{{PEERS}}

# ==============================================================================
# Producer Configuration
# ==============================================================================
# Enabled only for producer role
# WARNING: Only enable producer mode if you are an authorized block producer
{{PRODUCER_CONFIG}}
